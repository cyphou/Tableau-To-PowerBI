{
  "metadata": {
    "name": "revenue_ytd",
    "version": "1.0.0",
    "author": "Migration Marketplace",
    "description": "Year-to-date revenue calculation using TOTALYTD",
    "tags": ["finance", "time-intelligence", "revenue"],
    "category": "dax_recipe",
    "tableau_function": "RUNNING_SUM with date filter",
