{
  "objectVersion": 4,
  "nodes": {
    "aa000001-0001-0001-0001-000000000001": {
      "nodeType": ".v1.LoadSql",
      "name": "App_Orders",
      "id": "aa000001-0001-0001-0001-000000000001",
      "baseType": "input",
      "nextNodes": [
        {"namespace": "Default", "nextNodeId": "aa000001-0001-0001-0001-000000000004", "nextNamespace": "Default"}
      ],
      "connectionId": "conn-app-db",
      "connectionAttributes": {
        "class": "postgres",
        "server": "app-db.foodfast.io",
        "port": "5432",
        "dbname": "food_delivery",
        "schema": "orders",
        "table": "order_log"
      },
      "fields": [
        {"name": "order_id", "type": "string"},
