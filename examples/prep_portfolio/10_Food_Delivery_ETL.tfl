      },
      "fields": [
        {"name": "RestaurantID", "type": "string"},
        {"name": "RestaurantName", "type": "string"},
        {"name": "cuisine_type", "type": "string"},
        {"name": "city", "type": "string"},
        {"name": "TotalOrders", "type": "integer"},
        {"name": "TotalRevenue", "type": "real"},
        {"name": "AvgOrderValue", "type": "real"},
        {"name": "AvgWaitTime", "type": "real"},
        {"name": "AvgTip", "type": "real"}
      ]
    }
  },
