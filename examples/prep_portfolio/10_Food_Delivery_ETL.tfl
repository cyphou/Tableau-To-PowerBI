        {"name": "discount_amount", "type": "real"},
        {"name": "status", "type": "string"},
        {"name": "platform", "type": "string"}
      ]
    },
    "aa000001-0001-0001-0001-000000000002": {
      "nodeType": ".v1.LoadCsv",
      "name": "Restaurants_Jan.csv",
      "id": "aa000001-0001-0001-0001-000000000002",
      "baseType": "input",
      "nextNodes": [
        {"namespace": "Default", "nextNodeId": "aa000001-0001-0001-0001-000000000005", "nextNamespace": "Default"}
      ],
      "connectionId": "conn-restaurants-jan",
      "connectionAttributes": {
        "class": "csv",
        "filename": "Restaurants_Jan.csv",
        "separator": ","
      },
      "fields": [
        {"name": "restaurant_id", "type": "string"},
        {"name": "restaurant_name", "type": "string"},
        {"name": "cuisine_type", "type": "string"},
        {"name": "city", "type": "string"},
        {"name": "state", "type": "string"},
