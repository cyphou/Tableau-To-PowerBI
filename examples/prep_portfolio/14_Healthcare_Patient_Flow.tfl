    "conn-ehr-procedures": {
      "connectionAttributes": {
        "class": "postgres",
        "server": "ehr-db.hospital.local",
        "port": "5432",
        "dbname": "ehr_system"
      }
    },
    "conn-icd10": {
      "connectionAttributes": {
