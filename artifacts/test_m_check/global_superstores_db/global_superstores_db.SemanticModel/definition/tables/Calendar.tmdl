	hierarchy 'Date Hierarchy'
		lineageTag: 58ed7951-1cea-43a9-809b-9eabd38634a0

		level Year
			ordinal: 0
			column: Year
			lineageTag: f2c845f9-9170-4c9f-ac19-09d56f2f9dc3

		level Quarter
			ordinal: 1
			column: Quarter
			lineageTag: e24c319e-6cd5-490a-832d-2061ab8811f2

		level Month
			ordinal: 2
			column: MonthName
			lineageTag: 969faf78-8cca-4bfb-a4bc-e149cd7d0a4e

