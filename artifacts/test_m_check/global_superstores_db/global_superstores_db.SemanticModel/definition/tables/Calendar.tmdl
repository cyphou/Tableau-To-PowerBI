table Calendar
	lineageTag: e0f8f1e3-0a88-42f1-841e-2717124819a4

	measure 'Year To Date' = TOTALYTD([Margin], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: d41f42e3-63be-41f7-bbcf-bada3e5cbe77

	measure 'Previous Year' = CALCULATE([Margin], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 673ce7a2-5e40-43a6-84fc-870623eb74ed

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 896835a5-df80-4934-8c49-bdbe0dc43fad

	column Date
		dataType: dateTime
		formatString: dd/mm/yyyy
