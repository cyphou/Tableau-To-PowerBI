table Calendar
	lineageTag: 5d8349fc-23ad-4159-9d95-d9ba59d2497d

	measure 'Year To Date' = TOTALYTD([Margin], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: dc0fc479-e86f-409b-abbf-466b042e9605

	measure 'Previous Year' = CALCULATE([Margin], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 019a1544-a9b7-48be-a0c2-a07799513c1c

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 9d1a07c5-a2cc-4134-8f0a-fe6a214dc6db

	column Date
		dataType: dateTime
		formatString: dd/mm/yyyy
