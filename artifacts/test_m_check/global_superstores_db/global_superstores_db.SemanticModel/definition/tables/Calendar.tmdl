	hierarchy 'Date Hierarchy'
		lineageTag: 3538628d-717e-4bf3-9b38-eefcf2ec52ed

		level Year
			ordinal: 0
			column: Year
			lineageTag: 29c9b973-b0c7-489b-9057-170b702d88ad

		level Quarter
			ordinal: 1
			column: Quarter
