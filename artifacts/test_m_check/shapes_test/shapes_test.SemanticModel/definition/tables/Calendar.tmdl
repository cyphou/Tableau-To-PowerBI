	hierarchy 'Date Hierarchy'
		lineageTag: 7c344900-ac7d-41db-9123-91b43cd7b263

		level Year
			ordinal: 0
			column: Year
			lineageTag: d94e5e72-5dda-4332-8fba-733af3ecaebe

		level Quarter
