table Calendar
	lineageTag: 30ad1fc3-6a52-4910-bb6e-68be4a6ee5d1

	measure 'Year To Date' = TOTALYTD([Profit Ratio], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: f6fdb653-6437-4523-9f4a-750ff45ded15

	measure 'Previous Year' = CALCULATE([Profit Ratio], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: b4cd54f3-67ba-49d4-aa59-a85fa51cd9af

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: b5d0dd47-5d0b-4fe7-91ed-fb3463caae1d

