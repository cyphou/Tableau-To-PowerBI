model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Orders","Regions","Calendar"]

ref table Orders
ref table Regions
ref table Calendar

ref relationship d7686afd-8a77-454d-bcee-f8e9b801e238
ref relationship f75b596c-392d-4d41-a0d1-1011ad4f3cb3

ref expression DataFolder

ref role 'Region Access'
ref role 'Is Current User'
ref role Managers
ref role Executives
ref role 'Region Match'

ref perspective 'Full Model'

