	hierarchy 'Date Hierarchy'
		lineageTag: 70b4e80f-2d8f-44ad-85d2-1afa016249cf

		level Year
			ordinal: 0
			column: Year
			lineageTag: c21be664-3b78-4c1f-a56a-7d669c7fcb28

		level Quarter
