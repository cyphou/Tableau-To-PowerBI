table Calendar
	lineageTag: ec58d46c-85c6-42f8-a912-17e2de24fe56

	measure 'Year To Date' = TOTALYTD([Budget Variance], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: b3cf7c38-e2d4-44e5-a75b-3579141ac9f6

	measure 'Previous Year' = CALCULATE([Budget Variance], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 230393af-91b3-4e41-b208-0ad16aad4bfb

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 94543602-918f-4ec8-98b5-b243fd36bd0c

