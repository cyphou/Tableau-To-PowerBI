	hierarchy 'Date Hierarchy'
		lineageTag: 4fd34b02-c7e8-458e-b558-b4687626ec66

		level Year
			ordinal: 0
			column: Year
			lineageTag: d22842ca-6f5b-4597-a997-5a535f11d7e3

		level Quarter
			ordinal: 1
			column: Quarter
			lineageTag: ac32be74-dd92-4183-8df0-054df60b5494

		level Month
