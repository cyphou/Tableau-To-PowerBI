table Calendar
	lineageTag: 8dd9c81d-a8c9-4155-9f08-27dfe18e5338

	measure 'Year To Date' = TOTALYTD([Budget Variance], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: fa09c5b7-0366-4d46-845e-13fe55bfc1ed

	measure 'Previous Year' = CALCULATE([Budget Variance], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 36ffa571-7088-4ee4-942f-b6d8695fcbf2

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 56542719-8442-4372-a014-00617caeff4d

	column Date
		dataType: dateTime
		formatString: dd/mm/yyyy
