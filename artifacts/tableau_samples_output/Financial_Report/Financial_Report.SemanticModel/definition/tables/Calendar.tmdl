table Calendar
	lineageTag: a940fa43-bfeb-4dbd-ad31-3aaef14fc5d4

	measure 'Year To Date' = TOTALYTD([Budget Variance], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 5e2d95ba-feb2-47cc-ba91-5ed2f0c0d13d

	measure 'Previous Year' = CALCULATE([Budget Variance], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: be9c1272-8e5c-4df4-95e8-7ddf62b08738

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 7837594b-2aaf-4736-bb56-d072e6f7306c

