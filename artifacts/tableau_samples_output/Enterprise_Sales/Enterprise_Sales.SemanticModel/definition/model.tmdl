model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Orders","Customers","Calendar","Target Margin","Top N"]

ref table Orders
ref table Customers
ref table Calendar
ref table 'Target Margin'
ref table 'Top N'

ref relationship 36a6c44e-67d0-44ff-b8f8-ea0114689ebf
ref relationship 95d822af-fd75-40ff-baa1-40ad0274a7fa
ref relationship fd2d0083-18f9-4e87-a2c9-684ee0e74a3a

ref expression DataFolder

ref role 'Territory Access'
ref role 'Is My Account'

ref perspective 'Full Model'

