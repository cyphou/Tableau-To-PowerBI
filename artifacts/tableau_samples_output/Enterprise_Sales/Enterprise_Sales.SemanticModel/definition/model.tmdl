model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Orders","Customers","Calendar","Target Margin","Top N"]

ref table Orders
ref table Customers
ref table Calendar
ref table 'Target Margin'
ref table 'Top N'

ref relationship 0d1922f9-1b03-41e0-8653-8a5f848fdc30
ref relationship f9bfc8b8-7922-4c99-9b31-efc4f8ab6821
ref relationship 4d95d704-522d-4a60-8dc7-3ecf6f04b095

ref expression DataFolder

ref role 'Territory Access'
ref role 'Is My Account'

ref perspective 'Full Model'

