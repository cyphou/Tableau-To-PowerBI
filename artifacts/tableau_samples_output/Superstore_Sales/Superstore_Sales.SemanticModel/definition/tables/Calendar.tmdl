	hierarchy 'Date Hierarchy'
		lineageTag: 6bc876ad-ad4e-4f32-af6b-b5033ba583c6

		level Year
			ordinal: 0
			column: Year
			lineageTag: bdf932b8-87cd-450f-b7a5-77a2e5124e4c

		level Quarter
			ordinal: 1
