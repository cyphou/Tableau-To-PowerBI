table Calendar
	lineageTag: f16747e7-29c6-476e-b6a6-2f06e65e80ce

	measure 'Year To Date' = TOTALYTD([Total Sales], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: bf0de930-6ebd-4caf-ad57-8acb738a5dda

	measure 'Previous Year' = CALCULATE([Total Sales], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: d42bce1b-2585-4e8c-be05-ffc62a8debaf

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: c566de80-faa4-44e5-ae87-b52a27bb213d

	column Date
