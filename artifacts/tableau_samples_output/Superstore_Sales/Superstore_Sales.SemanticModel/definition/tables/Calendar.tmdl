table Calendar
	lineageTag: 9b18d08b-00f0-4c7f-aaf1-a3e44b0849ed

	measure 'Year To Date' = TOTALYTD([Total Sales], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 03c454b3-8b45-4fa2-8fe3-387dbb263766

	measure 'Previous Year' = CALCULATE([Total Sales], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: ae591c98-ce50-4457-9280-7b28a42f24fe

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 123fcd6e-9aec-4fc8-bcf3-adf5d06ed38a

