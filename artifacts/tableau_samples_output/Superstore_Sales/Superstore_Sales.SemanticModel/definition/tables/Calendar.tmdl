	hierarchy 'Date Hierarchy'
		lineageTag: 3ad704f3-9f66-4204-8f80-6256bce42c6e

		level Year
			ordinal: 0
			column: Year
			lineageTag: ff16d8ce-c022-45ae-8dfe-1cb281f4d1a1

		level Quarter
