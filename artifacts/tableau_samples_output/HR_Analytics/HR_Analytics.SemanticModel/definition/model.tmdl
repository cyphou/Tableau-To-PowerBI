model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Employees","Calendar"]

ref table Employees
ref table Calendar

ref relationship accaec1a-f015-4205-adff-2391f4a39b05

ref expression DataFolder

ref perspective 'Full Model'

