	hierarchy 'Date Hierarchy'
		lineageTag: 39f6eecf-f7a6-4782-9190-17cfd100469f

		level Year
			ordinal: 0
			column: Year
			lineageTag: 5638be6c-919a-49a5-a774-b1ab795d255e

		level Quarter
			ordinal: 1
