table Calendar
	lineageTag: 45e2bd9c-9cbf-4ec4-b7d8-ff1c86732145

	measure 'Year To Date' = TOTALYTD([Total Compensation], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 666e48c9-0030-491a-9151-f966ba1803fc

	measure 'Previous Year' = CALCULATE([Total Compensation], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 8f1c40c8-1d30-46c1-957d-5a020f28a1f9

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: dbea020c-e81b-4461-ac3d-a04671eb7d20

	column Date
