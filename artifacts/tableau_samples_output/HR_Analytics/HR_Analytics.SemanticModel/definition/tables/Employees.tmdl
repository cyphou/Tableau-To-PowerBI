table Employees
	lineageTag: dea18957-c2c5-442b-affb-6342ea2d9c5c

	measure 'Average Salary' = AVERAGE('Employees'[Salary])
		formatString: #,0.00
		displayFolder: Measures
		lineageTag: 2fa2a5ea-52b9-4a90-a2a6-d64e559e3474

	measure 'Employee Count' = COUNT('Employees'[EmployeeID])
		displayFolder: Measures
		lineageTag: 7e56689e-9384-4d6b-bd90-98e204bbf742

	measure 'Total Compensation' = SUM('Employees'[Salary]) * 1.25
