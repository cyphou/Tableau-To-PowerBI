	column 'Campaign Days' = DATEDIFF('Campaigns'[start_date], 'Campaigns'[end_date], DAY)
		dataType: int64
		lineageTag: 9ffbb65e-7975-4837-b649-5edeb24cc85c
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Budget Band' = INT('Campaigns'[budget] / 1000) * 1000
		dataType: int64
		lineageTag: c29bc5d8-f557-4665-9b66-517c98de2beb
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition 'Campaigns-a9dad0c5-88bd-45c9-9f37-2062d969f541' = m
