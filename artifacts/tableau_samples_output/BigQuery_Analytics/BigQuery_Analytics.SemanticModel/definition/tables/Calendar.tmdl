table Calendar
	lineageTag: 5c65b6d0-0cc1-4647-8c84-306e05d09fe5

	measure 'Year To Date' = TOTALYTD([Total Revenue], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: ba705b4c-c677-4dcd-9db8-718dded29c12

	measure 'Previous Year' = CALCULATE([Total Revenue], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 4564298c-cc73-4b18-9adb-1ac82ecc3431

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: ea026ad2-cadb-4350-b35c-1bc96151c772

