table Calendar
	lineageTag: dd7d1daa-9737-4286-86e6-5f0d1f921a9b

	measure 'Year To Date' = TOTALYTD([Total Revenue], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 998db04a-5936-48a3-99ab-c0b0c3a4a770

	measure 'Previous Year' = CALCULATE([Total Revenue], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: ccace479-3c8c-42e4-b4a8-786ff175c2d3

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 4fbf6f1a-78dd-4747-a727-0adcd9d2c7a8

