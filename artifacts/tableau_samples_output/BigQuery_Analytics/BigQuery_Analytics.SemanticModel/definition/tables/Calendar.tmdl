	hierarchy 'Date Hierarchy'
		lineageTag: 155eeb8e-8adc-42ff-ab61-d0a85715ed8f

		level Year
			ordinal: 0
			column: Year
			lineageTag: b54715ee-9d94-4f10-b0ca-6763d41beb11

		level Quarter
			ordinal: 1
