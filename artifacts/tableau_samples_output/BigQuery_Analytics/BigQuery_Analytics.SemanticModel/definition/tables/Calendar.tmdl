	hierarchy 'Date Hierarchy'
		lineageTag: dc4790e5-f9e6-498a-b2b5-d41c267edcad

		level Year
			ordinal: 0
			column: Year
			lineageTag: 666537ae-0948-44b4-aef6-e183eac1ebca

		level Quarter
