model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Demographics","Customer_360","Calendar"]

ref table Demographics
ref table Customer_360
ref table Calendar

ref relationship c1d54365-35e6-4040-aea5-7765b3a22724
ref relationship 2bfc1970-eb30-405b-8655-8d05ab869a1c

ref expression DataFolder

ref role 'Region Access'
ref role 'Is Current User'
ref role Managers
ref role Executives
ref role 'Region Match'

ref perspective 'Full Model'

