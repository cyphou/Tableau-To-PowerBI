model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Inventory_Levels","Inventory_Status","Calendar"]

ref table Inventory_Levels
ref table Inventory_Status
ref table Calendar

ref relationship 453f2152-9553-4f73-abef-ad073fa5e5b2

ref expression DataFolder

ref role 'Region Access'
ref role 'Is Current User'
ref role Managers
ref role Executives
ref role 'Region Match'

ref perspective 'Full Model'

