model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Orders_Clean","Calendar"]

ref table Orders_Clean
ref table Calendar

ref relationship 99354778-9fef-4e78-ab08-892127e646f9

ref expression DataFolder

ref role 'Region Access'
ref role 'Is Current User'
ref role Managers
ref role Executives
ref role 'Region Match'

ref perspective 'Full Model'

