role 'Region Access'
	modelPermission: read
	annotation MigrationNote = "Migrated from Tableau user filter 'Region Access'. Each user is mapped to their allowed Region values inline. Consider creating a security table for dynamic RLS."

	tablePermission Returns_Processed
		filterExpression = (USERPRINCIPALNAME() = "alice@company.com" && [Region] IN {"East", "West"}) || (USERPRINCIPALNAME() = "bob@company.com" && [Region] = "Central") || (USERPRINCIPALNAME() = "carol@company.com" && [Region] = "South")

role 'Is Current User'
	modelPermission: read
	annotation MigrationNote = "Migrated from Tableau calculated security 'Is Current User'. Original formula: [CustomerEmail] = USERNAME()"

	tablePermission Returns_Processed
		filterExpression = 'Returns_Processed'[CustomerEmail] = USERPRINCIPALNAME()

role Managers
	modelPermission: read
	annotation MigrationNote = "Migrated from Tableau ISMEMBEROF(\"Managers\"). Assign Azure AD group members to this RLS role."

	tablePermission Returns_Processed
		filterExpression = TRUE()  /* Members of role 'Managers' have access */

role Executives
	modelPermission: read
	annotation MigrationNote = "Migrated from Tableau ISMEMBEROF(\"Executives\"). Assign Azure AD group members to this RLS role."

	tablePermission Returns_Processed
		filterExpression = TRUE()  /* Members of role 'Executives' have access */

role 'Region Match'
	modelPermission: read
	annotation MigrationNote = "Migrated from Tableau calculated security 'Region Match'. Original formula: [RegionManager] = FULLNAME()"

	tablePermission Returns_Processed
		filterExpression = 'Returns_Processed'[RegionManager] = USERPRINCIPALNAME()

