model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Returns_Processed","Calendar"]

ref table Returns_Processed
ref table Calendar

ref relationship fbbe24c0-76ba-4e55-9b29-d6cf74ef91e5

ref expression DataFolder

ref role 'Region Access'
ref role 'Is Current User'
ref role Managers
ref role Executives
ref role 'Region Match'

ref perspective 'Full Model'

