table Calendar
	lineageTag: f0b7aebd-93ae-4ccd-a3db-71273b7f20de

	measure 'Year To Date' = TOTALYTD([Profit Ratio], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 75f4c4e1-c7a4-4789-9516-bfab256f4426

	measure 'Previous Year' = CALCULATE([Profit Ratio], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: ba082a7c-3ce0-4f8e-8df6-320a97664cba

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: ffb00974-40d4-4a7e-aa0e-849ab99df985

