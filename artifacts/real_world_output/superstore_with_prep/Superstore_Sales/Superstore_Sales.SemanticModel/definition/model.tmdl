model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Orders","Returns","People","Customers","Regional_Sales_Summary","Calendar"]

ref table Orders
ref table Returns
ref table People
ref table Customers
ref table Regional_Sales_Summary
ref table Calendar

ref expression DataFolder

ref perspective 'Full Model'

