model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Orders$","Calendar","Top Customers","Profit Bin Size"]

ref table 'Orders$'
ref table Calendar
ref table 'Top Customers'
ref table 'Profit Bin Size'

ref relationship 7fe84995-5688-49e1-9319-655e5a1ef9b7

ref expression DataFolder

ref perspective 'Full Model'

