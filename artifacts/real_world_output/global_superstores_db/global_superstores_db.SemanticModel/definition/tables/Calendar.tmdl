table Calendar
	lineageTag: b9a224be-18f2-4ad2-b4be-805660b3a2ac

	measure 'Year To Date' = TOTALYTD([Margin], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: bd8d2983-d441-4037-ab23-9dd6179c44d3

	measure 'Previous Year' = CALCULATE([Margin], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 98b70aa3-644e-4bf3-ac36-5bfcf833f091

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 029ea3a9-2ae1-4893-aae7-0840aaf18994

