	hierarchy 'Date Hierarchy'
		lineageTag: dd6a528f-18f7-409f-b260-4734bebb2ec3

		level Year
			ordinal: 0
			column: Year
			lineageTag: e76e5999-0880-4af8-aa6c-b3497648e924

		level Quarter
			ordinal: 1
			column: Quarter
			lineageTag: 227734ce-9dd2-4e6e-b31e-3e1dabb1261b

