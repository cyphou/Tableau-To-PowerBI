table Calendar
	lineageTag: a86ac39e-2fe6-4aee-9b4f-16fc71867200

	measure 'Year To Date' = TOTALYTD([Margin], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 04a80984-f514-45e2-be7b-8bbc7033f51e

	measure 'Previous Year' = CALCULATE([Margin], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 9c2f7d94-8a6f-4833-82c5-b0cde9c35112

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 038f3729-f20a-4437-a5c1-f255a1d5af1e

