table Calendar
	lineageTag: 7e98effe-b664-4815-8034-79c525ff1252

	measure 'Year To Date' = TOTALYTD([Margin], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 6d8b1acd-f953-42cb-a531-16791d873cfa

	measure 'Previous Year' = CALCULATE([Margin], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 3a89fe61-0ed6-4009-aad2-f88bf4345fce

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: c3c85688-a730-4670-b297-b5a6d0647cae

	column Date
		dataType: dateTime
		formatString: dd/mm/yyyy
