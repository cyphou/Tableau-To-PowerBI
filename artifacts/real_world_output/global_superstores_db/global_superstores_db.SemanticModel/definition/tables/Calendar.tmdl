table Calendar
	lineageTag: 9921c7a3-4417-4419-a820-79519e307162

	measure 'Year To Date' = TOTALYTD([Margin], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 6b09366e-0251-4d70-9346-b70ebc8a4508

	measure 'Previous Year' = CALCULATE([Margin], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: c5a39da9-d160-4313-8d63-dd5004c3efee

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 4b115835-de27-4cc3-a635-165f0bc7428c

	column Date
		dataType: dateTime
