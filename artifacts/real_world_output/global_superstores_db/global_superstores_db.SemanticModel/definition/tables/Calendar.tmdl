	hierarchy 'Date Hierarchy'
		lineageTag: 0bf402f7-bf39-4c3a-9823-851f0b2e4512

		level Year
			ordinal: 0
			column: Year
			lineageTag: 4ea0a7cf-581a-460a-b711-531ae1159e4e

		level Quarter
			ordinal: 1
			column: Quarter
