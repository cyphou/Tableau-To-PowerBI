	hierarchy 'Date Hierarchy'
		lineageTag: 0ebeab3c-d04d-4f80-8e9b-a7e168ea385d

		level Year
			ordinal: 0
			column: Year
			lineageTag: be1b72f9-945a-4047-a9fe-11ce5e6df772

		level Quarter
