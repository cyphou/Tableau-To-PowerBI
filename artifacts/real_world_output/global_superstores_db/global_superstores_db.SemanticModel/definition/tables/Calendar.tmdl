table Calendar
	lineageTag: 2757f92f-2483-4f30-aace-329630945f65

	measure 'Year To Date' = TOTALYTD([Margin], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: c0e28ba3-f945-4e96-a34b-7c8ba6131897

	measure 'Previous Year' = CALCULATE([Margin], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 3417e826-3988-4f95-803f-83b9fc3e026b

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 34ca458c-8e9e-4342-a5f7-18a83aa43e85

	column Date
		dataType: dateTime
