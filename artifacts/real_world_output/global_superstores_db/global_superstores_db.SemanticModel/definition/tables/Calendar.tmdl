table Calendar
	lineageTag: c3bc985a-8fa5-4483-b0aa-4b130af3b4da

	measure 'Year To Date' = TOTALYTD([Margin], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: bdf2db38-5053-4c08-b566-6900a2376836

	measure 'Previous Year' = CALCULATE([Margin], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 7273c5e2-ef5e-49a9-a4a1-eb8c65d213f2

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 533a07b0-4240-41d3-aa07-69a9322daf54

	column Date
		dataType: dateTime
		formatString: dd/mm/yyyy
