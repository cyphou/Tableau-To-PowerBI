	hierarchy 'Date Hierarchy'
		lineageTag: be1a2a6a-3932-41c7-a200-61974c7466e2

		level Year
			ordinal: 0
			column: Year
			lineageTag: ed6ba631-62ab-4994-be67-109869398420

		level Quarter
			ordinal: 1
			column: Quarter
