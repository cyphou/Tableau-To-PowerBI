	hierarchy 'Date Hierarchy'
		lineageTag: 992a48f2-e9e6-4126-af2d-b0cb13ffebad

		level Year
			ordinal: 0
			column: Year
			lineageTag: 627222fb-eaa9-4010-94ca-c73a49cbe07d

		level Quarter
			ordinal: 1
