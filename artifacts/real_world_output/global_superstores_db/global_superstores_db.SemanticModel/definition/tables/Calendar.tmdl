	hierarchy 'Date Hierarchy'
		lineageTag: 04e9948b-1c3c-44fa-b028-ce98735ec12d

		level Year
			ordinal: 0
			column: Year
			lineageTag: 1f5944bc-96af-4a9b-8c8e-ca95bf670b74

		level Quarter
			ordinal: 1
			column: Quarter
			lineageTag: 96c103b3-5047-4a05-9e54-8dd6c6a90ca0

		level Month
			ordinal: 2
