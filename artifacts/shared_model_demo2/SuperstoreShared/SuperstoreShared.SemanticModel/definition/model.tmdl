model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Orders","Returns","People","Customers","Calendar","Target Margin","Top N"]

ref table Orders
ref table Returns
ref table People
ref table Customers
ref table Calendar
ref table 'Target Margin'
ref table 'Top N'

ref relationship 4fb913b2-7a22-4846-9328-691e7d870f75
ref relationship dfbadfe3-7445-4b78-b69e-584432d6a2c3
ref relationship 5d986eae-81fa-4974-9106-fd0408237681
ref relationship b5544efc-1ae6-4669-b609-60f3bc82bfc5
ref relationship 14742fd5-b7f3-4343-aabf-3bfdbb208cc5

ref expression DataFolder

ref role 'Territory Access'
ref role 'Is My Account'

ref perspective 'Full Model'

