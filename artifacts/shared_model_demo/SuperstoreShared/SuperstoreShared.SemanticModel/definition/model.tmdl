		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Orders","Returns","People","Customers","Calendar","Target Margin","Top N"]

ref table Orders
ref table Returns
ref table People
ref table Customers
ref table Calendar
ref table 'Target Margin'
ref table 'Top N'

