model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Orders","Returns","People","Customers","Calendar","Target Margin","Top N"]

ref table Orders
ref table Returns
ref table People
ref table Customers
ref table Calendar
ref table 'Target Margin'
ref table 'Top N'

ref relationship 3751b6aa-4419-41ce-b46a-04e98c367156
ref relationship 8e3121d5-5481-4779-aab8-cdcdb36fe533
ref relationship d31302bf-1946-4cf2-b7c6-335993a0e977
ref relationship e0498544-33d6-45ce-9478-68e3c36ce68d
ref relationship ada30725-0eb2-4a76-8a64-2dc2a4a0a886

ref expression DataFolder

ref role 'Territory Access'
ref role 'Is My Account'

ref perspective 'Full Model'

