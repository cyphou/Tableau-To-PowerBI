	hierarchy 'Date Hierarchy'
		lineageTag: 3012c65a-39f5-477b-97db-d97e20a66baf

		level Year
			ordinal: 0
			column: Year
			lineageTag: 6c549061-1a0d-43e7-9f60-311e7a393e7a

		level Quarter
			ordinal: 1
			column: Quarter
