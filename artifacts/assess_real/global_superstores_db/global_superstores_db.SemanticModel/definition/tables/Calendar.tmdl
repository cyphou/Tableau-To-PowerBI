table Calendar
	lineageTag: 5e4438c0-5473-48f1-9e30-3a6901c9beb2

	measure 'Year To Date' = TOTALYTD([Margin], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: fa7bac12-d3c9-47d9-b65f-6a802dafe3b0

	measure 'Previous Year' = CALCULATE([Margin], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 31233675-eaad-4ae4-a552-85781a7d4625

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 7700a79e-0080-434c-918b-9ba88d18139e

	column Date
		dataType: dateTime
		formatString: dd/mm/yyyy
