table Calendar
	lineageTag: ee31c8b8-76d6-4b06-931d-afb427d0a68c

	measure 'Year To Date' = TOTALYTD([Profit Ratio], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 416cd1d4-0d08-4b93-8b1d-d8be023fe513

	measure 'Previous Year' = CALCULATE([Profit Ratio], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 55f1bf68-3b52-46c2-936c-e1be74723ec6

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 56a82478-8c7d-4dd6-b214-7cd698adc560

	column Date
		dataType: dateTime
		formatString: dd/mm/yyyy
		lineageTag: d60bd5d8-a035-43b4-b629-f7397d811abd
		summarizeBy: none
		sourceColumn: Date
		isKey
		dataCategory: DateTime

		annotation SummarizationSetBy = Automatic

	column Year
		dataType: int64
		lineageTag: 700715d0-f7b9-4cdb-ac47-259016eeb4a9
