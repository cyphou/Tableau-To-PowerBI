	hierarchy 'Date Hierarchy'
		lineageTag: b05e12c9-5db1-44c5-8a61-75ff9dd7a9b3

		level Year
			ordinal: 0
			column: Year
			lineageTag: ea1d111e-8cf0-4ef0-99a5-a897ba30053f

		level Quarter
			ordinal: 1
			column: Quarter
			lineageTag: 0b95e85c-daca-44ae-b098-7c1214406ca3

		level Month
			ordinal: 2
			column: MonthName
			lineageTag: df593b5c-d1e4-46ac-870a-e216fe0f681d

