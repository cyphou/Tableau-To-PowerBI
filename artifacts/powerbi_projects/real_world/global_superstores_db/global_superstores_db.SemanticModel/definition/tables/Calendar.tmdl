table Calendar
	lineageTag: 80572e16-1276-4f2d-9183-7a952d7a4c89

	measure 'Year To Date' = TOTALYTD([Margin], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 203a200f-2297-4d20-93da-b65a0c17737a

	measure 'Previous Year' = CALCULATE([Margin], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 1010181e-acaf-4873-aa68-0b1729b4fe44

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: a28c760c-812e-40fb-b07f-2c9ac3a4bc10

	column Date
		dataType: dateTime
		formatString: dd/mm/yyyy
