model Model
	culture: fr-FR
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Orders","Returns","People","Calendar"]

ref table Orders
ref table Returns
ref table People
ref table Calendar

ref expression DataFolder

ref perspective 'Full Model'

ref culture 'fr-FR'

