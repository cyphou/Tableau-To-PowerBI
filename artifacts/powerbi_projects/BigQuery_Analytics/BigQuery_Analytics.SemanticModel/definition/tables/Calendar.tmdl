	hierarchy 'Date Hierarchy'
		lineageTag: ab78e0b9-a5ce-4075-bcb2-84ebea89df52

		level Year
			ordinal: 0
			column: Year
			lineageTag: b76d20e2-e857-407e-8784-5325f659d131

		level Quarter
			ordinal: 1
