	hierarchy 'Date Hierarchy'
		lineageTag: 9945b7ee-f0f2-49a1-9ebf-c4397343eb20

		level Year
			ordinal: 0
			column: Year
			lineageTag: a3bb7e96-764f-4fa9-ac5a-3846ef22bd39

		level Quarter
			ordinal: 1
			column: Quarter
			lineageTag: 96be50c5-5e35-48d8-b4e8-d8db8da29498

		level Month
			ordinal: 2
			column: MonthName
			lineageTag: b95f5514-5eb6-4cbf-b644-213923555c59

		level Day
			ordinal: 3
