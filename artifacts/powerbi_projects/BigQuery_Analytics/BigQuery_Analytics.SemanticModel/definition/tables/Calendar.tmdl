	hierarchy 'Date Hierarchy'
		lineageTag: 01eab8ea-f766-4478-9459-0e9be8f53170

		level Year
			ordinal: 0
			column: Year
			lineageTag: e0463f2d-b2d7-4ee1-b022-307c3e9b9c56

		level Quarter
			ordinal: 1
			column: Quarter
			lineageTag: c1d52932-1764-4dc6-b936-d0e13ef1a8a0

		level Month
			ordinal: 2
			column: MonthName
			lineageTag: 9a849353-4843-41d4-b8a6-3ab1e30a0e23

		level Day
			ordinal: 3
