table Calendar
	lineageTag: 9f9faaa1-5528-4b98-a665-178987122c37

	measure 'Year To Date' = TOTALYTD([Total Revenue], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: abb0f99c-5d90-4079-8d1b-23f5ec5e38a0

	measure 'Previous Year' = CALCULATE([Total Revenue], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 50cf08cc-5f8e-434b-bbe1-ab8efc128513

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: be896fc8-8751-4e85-8534-04659177e0fe

