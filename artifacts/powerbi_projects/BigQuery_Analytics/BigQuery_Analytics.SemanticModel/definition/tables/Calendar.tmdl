table Calendar
	lineageTag: 75d7eb67-4d7b-4c4c-931e-d78ed37fcf7e

	measure 'Year To Date' = TOTALYTD([Total Revenue], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 2c4c7eef-f46c-412b-a717-e8608bd86945

	measure 'Previous Year' = CALCULATE([Total Revenue], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 71c4ba52-0d34-49e3-99a0-db7e8d0b3e41

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: a3a3f922-f119-4a86-a472-6410e7b99ba3

	column Date
		dataType: dateTime
