table Calendar
	lineageTag: 4aa2d5c8-3557-4e1b-a0a3-0077ae57843a

	measure 'Year To Date' = TOTALYTD([Total Revenue], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 19e118e0-8c7e-4afd-8bca-164ad442b43e

	measure 'Previous Year' = CALCULATE([Total Revenue], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: aa71ff8c-c781-43a2-8cc2-37acf71598ab

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 7411e8ed-aaf3-42ac-842c-a6e878563fe6

	column Date
		dataType: dateTime
		formatString: dd/mm/yyyy
