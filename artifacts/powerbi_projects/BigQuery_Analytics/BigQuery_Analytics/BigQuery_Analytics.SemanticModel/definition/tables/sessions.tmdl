	column revenue
		dataType: double
		formatString: #,0.00
		lineageTag: cf0a27d0-8501-4493-a09b-cfc25e67e006
		summarizeBy: sum
		sourceColumn: revenue

		annotation SummarizationSetBy = Automatic

	column 'Channel Category' = IF('sessions'[channel] = "Organic Search" || 'sessions'[channel] = "Paid Search", "Search", IF('sessions'[channel] = "Social" || 'sessions'[channel] = "Referral", "Social/Referral", IF('sessions'[channel] = "Direct", "Direct", "Other")))
		dataType: string
		lineageTag: 67fb74d4-c7f1-4c4e-a2ef-e42f3816593c
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Engagement Level' = IF('sessions'[page_views] >= 10, "High", IF('sessions'[page_views] >= 5, "Medium", "Low"))
		dataType: string
		lineageTag: e2a75897-7d3b-465f-bac7-083564f0fed4
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Days Since Signup' = DATEDIFF(RELATED('users'[signup_date]), TODAY(), DAY)
		dataType: int64
		lineageTag: e2f4687c-5b40-471e-a461-9ce4f3a929fd
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition 'sessions-160b54b9-395a-4920-9ae9-c80a182f072c' = m
		mode: import
		source =
				let
				    // Source Google BigQuery: my-analytics-project.web_data
