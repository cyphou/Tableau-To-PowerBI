		lineageTag: a8ee4e8c-fa10-4b3b-88b7-fd2f4f6d90d7
		summarizeBy: sum
		sourceColumn: page_views

		annotation SummarizationSetBy = Automatic

	column session_duration
		dataType: double
		formatString: #,0.00
		lineageTag: 628c3538-e0c2-4099-afcf-b66462e48e09
		summarizeBy: sum
		sourceColumn: session_duration

