	hierarchy 'Date Hierarchy'
		lineageTag: 286d3d45-6816-4fcc-a29f-4b5a4601a0fb

		level Year
			ordinal: 0
			column: Year
			lineageTag: 0f4e5d9c-8352-492d-b26e-dfdde672d121

		level Quarter
			ordinal: 1
			column: Quarter
			lineageTag: e11bb6be-77a9-4e64-9cb3-30bc93073ca1

		level Month
			ordinal: 2
			column: MonthName
			lineageTag: 253508a7-79f8-4a1e-946e-4da77befab81

		level Day
			ordinal: 3
