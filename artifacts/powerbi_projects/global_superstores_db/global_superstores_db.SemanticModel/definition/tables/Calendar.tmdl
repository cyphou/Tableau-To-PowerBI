table Calendar
	lineageTag: d69cf92f-207a-4ea2-ab7c-2ebc91e4ff9d

	measure 'Year To Date' = TOTALYTD([Margin], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 59550b55-fae3-4144-9fc3-323a55b61c6a

	measure 'Previous Year' = CALCULATE([Margin], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: e9a7ef31-5132-4840-a5db-d48a2cb19de7

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: cac02d5d-25c1-4987-a764-18e33531c809

	column Date
		dataType: dateTime
		formatString: dd/mm/yyyy
