table Calendar
	lineageTag: 03bf77e7-ab02-4d6f-a33c-ffd85bd8a7b1

	measure 'Year To Date' = TOTALYTD([Margin], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 9a640ce0-3b63-4393-9fe8-89e3eab2b87b

	measure 'Previous Year' = CALCULATE([Margin], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: c05b2a35-5ad4-45ef-a582-955f6df6a686

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 083dfd24-4f64-4e15-b0a0-fb5ff4eba3a5

	column Date
		dataType: dateTime
