	hierarchy 'Date Hierarchy'
		lineageTag: faae7c8b-70e9-4d28-a5da-9d76b2e410e8

		level Year
			ordinal: 0
			column: Year
			lineageTag: 57777f85-5306-4152-a1d2-49eb5021360d

		level Quarter
			ordinal: 1
			column: Quarter
