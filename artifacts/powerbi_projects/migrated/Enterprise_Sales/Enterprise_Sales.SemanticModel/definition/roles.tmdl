role 'Territory Access'
	modelPermission: read
	annotation MigrationNote = "Migrated from Tableau user filter 'Territory Access'. Each user is mapped to their allowed territory values inline. Consider creating a security table for dynamic RLS."

	tablePermission Orders
		filterExpression = (USERPRINCIPALNAME() = "john@acme.com" && [territory] IN {"North", "South"}) || (USERPRINCIPALNAME() = "jane@acme.com" && [territory] IN {"East", "West"}) || (USERPRINCIPALNAME() = "mike@acme.com" && [territory] = "North")

role 'Is My Account'
	modelPermission: read
	annotation MigrationNote = "Migrated from Tableau calculated security 'Is My Account'. Original formula: [customer_email] = USERNAME()"

	tablePermission Customers
		filterExpression = [customer_email] = USERPRINCIPALNAME()

