table Calendar
	lineageTag: a917e9fb-92c0-4d62-9ad1-98a956d73f2c

	measure 'Year To Date' = TOTALYTD([Total Sales], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 94460d0b-b76a-495c-844d-9fbdc8a88435

	measure 'Previous Year' = CALCULATE([Total Sales], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 62d75f2f-9240-428a-b096-e4a6e30db2f3

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 2dc899f6-cc62-440f-862e-9082ee06ca4e

	column Date
		dataType: dateTime
		formatString: dd/mm/yyyy
