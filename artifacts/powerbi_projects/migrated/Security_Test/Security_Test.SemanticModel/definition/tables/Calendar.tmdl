	hierarchy 'Date Hierarchy'
		lineageTag: 1098cf46-86a1-4499-ac49-35116162e40b

		level Year
			ordinal: 0
			column: Year
			lineageTag: 6f4d8ce7-dcc2-4ca9-b138-1795f0d74cdd

		level Quarter
			ordinal: 1
			column: Quarter
			lineageTag: 4ae33b71-0911-45b1-9e63-6420fdfef4dd

		level Month
