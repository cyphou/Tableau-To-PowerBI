table Calendar
	lineageTag: 3ab7a2f4-e895-40ae-bc49-4505cb23b5c9

	measure 'Year To Date' = TOTALYTD([Margin], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 6b1722c2-8e29-4457-8bc7-d3bcb4951587

	measure 'Previous Year' = CALCULATE([Margin], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 895e9473-1baf-4564-858c-291e6e0e4ad7

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 1d5b4c88-6514-4ff2-a84b-5473b3157692

	column Date
		dataType: dateTime
		formatString: dd/mm/yyyy
