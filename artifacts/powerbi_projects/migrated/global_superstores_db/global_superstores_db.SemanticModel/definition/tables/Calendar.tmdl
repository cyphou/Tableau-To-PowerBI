	hierarchy 'Date Hierarchy'
		lineageTag: 01b4a932-f939-41bc-9f56-18bc585c6060

		level Year
			ordinal: 0
			column: Year
			lineageTag: d24dd603-1f82-4152-b69e-da497fe21d30

		level Quarter
			ordinal: 1
			column: Quarter
			lineageTag: b6c26f5d-3eb3-4868-aa01-fa3ec44afdb5

		level Month
			ordinal: 2
			column: MonthName
			lineageTag: 9c61727f-9135-4a26-966b-440cac11cad9

		level Day
			ordinal: 3
