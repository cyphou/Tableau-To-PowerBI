model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Campaigns","Leads","Calendar","Min Budget"]

ref table Campaigns
ref table Leads
ref table Calendar
ref table 'Min Budget'

ref expression DataFolder

ref perspective 'Full Model'

