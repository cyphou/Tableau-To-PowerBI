table Calendar
	lineageTag: 1a6057e4-8a60-4e36-9aeb-43ec6e8c3815

	measure 'Year To Date' = TOTALYTD([Total Sales], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 76c4398c-fa7c-47a0-84e4-89e8d3f1d753

	measure 'Previous Year' = CALCULATE([Total Sales], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 4fb8b8d8-d209-4f6b-964e-789dd3559286

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: dd6d0d69-fa6e-4ae1-b378-265421a490c6

	column Date
		dataType: dateTime
