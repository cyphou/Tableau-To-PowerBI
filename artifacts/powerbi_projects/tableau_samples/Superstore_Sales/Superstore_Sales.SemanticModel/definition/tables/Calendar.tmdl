	hierarchy 'Date Hierarchy'
		lineageTag: 8270f093-e958-4500-8cee-709423655455

		level Year
			ordinal: 0
			column: Year
			lineageTag: b1d83658-ee77-4ea0-aaff-57499a597ace

		level Quarter
			ordinal: 1
			column: Quarter
			lineageTag: 044f11bd-704a-4f47-82e7-dd174db250aa

		level Month
			ordinal: 2
