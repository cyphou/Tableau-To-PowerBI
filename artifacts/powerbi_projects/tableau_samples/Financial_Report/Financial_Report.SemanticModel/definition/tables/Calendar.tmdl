	hierarchy 'Date Hierarchy'
		lineageTag: 96fc4499-0524-44c9-a7b4-f4c176c62c08

		level Year
			ordinal: 0
			column: Year
			lineageTag: 313554b4-c5b9-49ee-8fb5-fb72bedd305b

		level Quarter
