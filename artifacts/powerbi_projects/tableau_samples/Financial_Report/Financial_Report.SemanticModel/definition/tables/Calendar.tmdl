table Calendar
	lineageTag: b7b4bca4-67b4-451d-94bd-2d5e37965719

	measure 'Year To Date' = TOTALYTD([Budget Variance], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: b8d3d673-6816-4235-bdd6-8f216cb2fe3c

	measure 'Previous Year' = CALCULATE([Budget Variance], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 1d9c2f2b-2ff0-454d-9f91-9983008781b0

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 80c0f70d-7029-4759-a634-d990b81b7bf9

	column Date
		dataType: dateTime
