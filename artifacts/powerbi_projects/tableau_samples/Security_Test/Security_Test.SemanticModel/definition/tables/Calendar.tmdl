table Calendar
	lineageTag: fc35f5c1-2288-4f35-9d73-8c6409768c5e

	measure 'Year To Date' = TOTALYTD([Total Sales], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 19d22e48-f63f-4375-96a2-b71a3b4279ea

	measure 'Previous Year' = CALCULATE([Total Sales], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: d6cb6830-ac2f-408b-bc80-84d15b5a6a33

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: aaf3047e-26f9-42f7-a83a-cb58d4ea350b

