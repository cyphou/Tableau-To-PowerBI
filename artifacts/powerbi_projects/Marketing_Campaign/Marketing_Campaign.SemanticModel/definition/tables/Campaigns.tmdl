table Campaigns
	lineageTag: ed979236-b340-463b-ac94-5479e6e4ac0c

	measure 'Non-Blank Leads' = COUNTA('Leads'[lead_name])
		displayFolder: Measures
		lineageTag: 920cceec-a15c-46dc-b654-07f3c84c1da7

	measure 'Budget Deal Correlation' = 0 /* CORR('Campaigns'[budget], 'Leads'[deal_value]): Pearson correlation — manual DAX needed */
		formatString: #,0.00
		displayFolder: Measures
		lineageTag: 8c115080-e6c2-41a8-bb8a-cd40419c99ae

	measure 'Spend Engagement Covar' = 0 /* COVAR('Campaigns'[spend], 'Leads'[engagement_score]): sample covariance — manual DAX needed */
		formatString: #,0.00
		displayFolder: Measures
		lineageTag: 89f01ee3-60be-4a9f-afc6-039b456e7daf

	measure 'Avg Deal by Channel' = CALCULATE(AVERAGE('Leads'[deal_value]))
		formatString: #,0.00
		displayFolder: Measures
		lineageTag: 301ecc94-8e9c-4eec-b6c7-71ce20428805

	measure 'Campaign ROI' = (SUM('Leads'[deal_value]) - SUM('Campaigns'[spend])) / SUM('Campaigns'[spend])
		formatString: #,0.00
		displayFolder: Measures
		lineageTag: b16fb037-852f-4e92-9980-740c2457c165

	measure 'Cost Per Lead' = SUM('Campaigns'[spend]) / DISTINCTCOUNT('Leads'[lead_id])
		formatString: #,0.00
		displayFolder: Measures
		lineageTag: 4739d726-5167-4501-837c-ed3359d21e5c

	measure 'Window Best ROI' = CALCULATE((SUM('Leads'[deal_value]) - SUM('Campaigns'[spend])) / SUM('Campaigns'[spend]), ALL('Campaigns'))
		formatString: #,0.00
		displayFolder: Measures
		lineageTag: 32fd17ff-8a64-492b-b88d-2835b6c1e864

	measure 'Window Worst ROI' = CALCULATE((SUM('Leads'[deal_value]) - SUM('Campaigns'[spend])) / SUM('Campaigns'[spend]), ALL('Campaigns'))
		formatString: #,0.00
		displayFolder: Measures
		lineageTag: 84fc25b5-f6d3-4335-b4cd-b14286241029

	measure 'Cumulative Leads' = CALCULATE(DISTINCTCOUNT('Leads'[lead_id]))
		displayFolder: Measures
		lineageTag: 7267d790-2200-4dfa-a37a-6cad4021dfb7

	measure 'Conversion Rate' = SUMX('Leads', IF('Leads'[lead_status] = "Won", 1, 0)) / COUNT('Leads'[lead_id])
		formatString: #,0.00
		displayFolder: Measures
		lineageTag: a686ee07-e06c-4cdc-bcc0-69608873985a

	measure 'Target Channel' = "Email"
		lineageTag: 4459d520-8a6c-4753-8ee6-463554c1a015

