table Calendar
	lineageTag: abf1dace-d7b6-4f17-a4f1-76459702fd89

	measure 'Year To Date' = TOTALYTD([Cost Per Lead], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 73204606-fbbf-4c62-842a-4a621f258da7

	measure 'Previous Year' = CALCULATE([Cost Per Lead], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: ede2d424-943c-499c-9866-fa6461eb3229

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 4df1d802-af74-41f3-8f3d-2ba6a27a19b6

	column Date
		dataType: dateTime
		formatString: dd/mm/yyyy
