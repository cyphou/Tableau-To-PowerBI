	hierarchy 'Date Hierarchy'
		lineageTag: 8ecf22cc-459e-4dcc-9c01-821f6f9e49ba

		level Year
			ordinal: 0
			column: Year
			lineageTag: 6f1fb838-4106-488d-8b41-0629d92d5f5f

		level Quarter
			ordinal: 1
			column: Quarter
