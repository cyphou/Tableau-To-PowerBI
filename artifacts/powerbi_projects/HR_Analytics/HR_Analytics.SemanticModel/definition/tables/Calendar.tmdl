	hierarchy 'Date Hierarchy'
		lineageTag: d6b90747-0711-48ec-b766-eece32518b83

		level Year
			ordinal: 0
			column: Year
			lineageTag: 51f665b9-458b-44a9-a1c0-e692758324b1

		level Quarter
			ordinal: 1
