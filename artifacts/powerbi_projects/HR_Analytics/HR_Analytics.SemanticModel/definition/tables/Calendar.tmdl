table Calendar
	lineageTag: cd7ee8b0-74fa-47f6-9fda-0f9630110a6f

	measure 'Year To Date' = TOTALYTD([Total Compensation], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 630eefa3-4e08-417d-9491-d019aea2b14f

	measure 'Previous Year' = CALCULATE([Total Compensation], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 30e6c01e-2528-4429-8ccf-cedab3d91e11

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 2951c3fd-9f89-4213-ae24-dab9f5d43c63

	column Date
		dataType: dateTime
