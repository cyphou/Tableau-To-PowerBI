model Model
	culture: fr-FR
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Employees","Calendar"]

ref table Employees
ref table Calendar

ref expression DataFolder

ref perspective 'Full Model'

ref culture 'fr-FR'

