table Calendar
	lineageTag: c7a28e84-3e29-46c3-8e08-569135e4c6a1

	measure 'Year To Date' = TOTALYTD([Budget Variance], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: ec437700-d694-4d7b-8c91-993e98183033

	measure 'Previous Year' = CALCULATE([Budget Variance], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 933caf62-225b-49ee-8617-3597b1c77588

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: bf84ae4e-f277-4214-8101-ec0a0c095deb

	column Date
		dataType: dateTime
		formatString: dd/mm/yyyy
