	hierarchy 'Date Hierarchy'
		lineageTag: aa8b354b-8576-411b-9867-fab8da854d41

		level Year
			ordinal: 0
			column: Year
			lineageTag: b1ee0ac7-cc92-43c3-ae94-891b5e6dfef4

		level Quarter
			ordinal: 1
			column: Quarter
