	hierarchy 'Date Hierarchy'
		lineageTag: d2f54fc2-6169-4750-90e3-c5aa593bc83b

		level Year
			ordinal: 0
			column: Year
			lineageTag: 837d4346-efd2-477a-b44a-43cc61c0c771

		level Quarter
			ordinal: 1
			column: Quarter
			lineageTag: afa81504-2e4a-4bca-a2eb-4da3d0e7472c

