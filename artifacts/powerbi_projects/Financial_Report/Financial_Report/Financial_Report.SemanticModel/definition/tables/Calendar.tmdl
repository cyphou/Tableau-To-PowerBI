table Calendar
	lineageTag: 88887a97-d3dd-46f6-8ac5-5a89fcd279d4

	measure 'Year To Date' = TOTALYTD([Budget Variance], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 010ca6cd-46c8-4d7a-a8b1-993b89e7b79d

	measure 'Previous Year' = CALCULATE([Budget Variance], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: f2ccbe32-fc8d-4996-a220-bf9fdbf740d3

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 12b0bc5a-871a-4b74-bf20-92354fca6c58

