model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Orders","People","Returns","Calendar","Top Customers","Profit Bin Size"]

ref table Orders
ref table People
ref table Returns
ref table Calendar
ref table 'Top Customers'
ref table 'Profit Bin Size'

ref expression DataFolder

ref perspective 'Full Model'

