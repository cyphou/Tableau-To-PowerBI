	hierarchy 'Date Hierarchy'
		lineageTag: 34cc031e-c276-4a76-864a-e62f3a3f45c0

		level Year
			ordinal: 0
			column: Year
			lineageTag: 4ae4fa64-ec00-4fba-8f2b-108adfba91b0

		level Quarter
			ordinal: 1
			column: Quarter
			lineageTag: e89d7ff5-5dee-41e0-a3c4-ce8424a76c5e

		level Month
			ordinal: 2
			column: MonthName
			lineageTag: 08390aea-908b-4e2d-86ef-4dc2c1c7169e

		level Day
			ordinal: 3
