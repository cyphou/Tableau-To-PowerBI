table Calendar
	lineageTag: ea10d3f5-db6e-46c8-a0a2-429dc046cd7b

	measure 'Year To Date' = TOTALYTD([Profit Ratio], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 173493a3-728d-49dd-8dfc-3593e418d221

	measure 'Previous Year' = CALCULATE([Profit Ratio], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: ecb80ceb-71e6-4547-b973-e67a9bd4bd35

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 1dfe9735-4852-4e81-847f-de467f12631c

	column Date
		dataType: dateTime
		formatString: dd/mm/yyyy
