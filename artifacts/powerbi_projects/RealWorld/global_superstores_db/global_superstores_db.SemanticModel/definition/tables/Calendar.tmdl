	hierarchy 'Date Hierarchy'
		lineageTag: 92ead191-dbd4-4207-9819-c8a4569e72c1

		level Year
			ordinal: 0
			column: Year
			lineageTag: 55177ee4-940f-4452-b1bd-6fc8e5414db8

		level Quarter
