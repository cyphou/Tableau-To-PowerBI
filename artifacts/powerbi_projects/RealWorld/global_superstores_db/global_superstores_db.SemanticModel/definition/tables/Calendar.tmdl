table Calendar
	lineageTag: cc80da6a-523f-4725-b19b-5697c73a7488

	measure 'Year To Date' = TOTALYTD([Margin], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 81ee9909-fd8d-42cc-a358-970ab73cb112

	measure 'Previous Year' = CALCULATE([Margin], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 01ec24b4-6f79-4b5f-8342-09d3b20184b1

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: def5ab12-2f93-43d9-9dd0-1836235bc04a

	column Date
		dataType: dateTime
