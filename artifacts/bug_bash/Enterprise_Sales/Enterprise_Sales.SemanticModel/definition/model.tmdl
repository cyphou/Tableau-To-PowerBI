model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Orders","Customers","Calendar","Target Margin","Top N"]

ref table Orders
ref table Customers
ref table Calendar
ref table 'Target Margin'
ref table 'Top N'

ref relationship efb14691-35c3-43b1-a194-022bf4ce1f8d
ref relationship 3be38976-f84d-408f-9fb6-d4b0b44f0df6
ref relationship f1140c17-b0c7-4bb0-889c-40b9544de78c

ref expression DataFolder

ref role 'Territory Access'
ref role 'Is My Account'

ref perspective 'Full Model'

