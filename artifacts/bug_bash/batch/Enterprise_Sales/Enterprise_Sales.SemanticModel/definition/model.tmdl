model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Orders","Customers","Calendar","Target Margin","Top N"]

ref table Orders
ref table Customers
ref table Calendar
ref table 'Target Margin'
ref table 'Top N'

ref relationship 51422349-d672-4338-8404-30b9e41ef8fc
ref relationship 41afd2af-8e27-4501-9b4a-be25cfbe7063
ref relationship fcb222fa-0326-4d4f-b4ae-1d92d0ee9d72

ref expression DataFolder

ref role 'Territory Access'
ref role 'Is My Account'

ref perspective 'Full Model'

