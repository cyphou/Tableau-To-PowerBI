	hierarchy 'Date Hierarchy'
		lineageTag: e181f304-40e4-4648-926c-8c05f94aad3b

		level Year
			ordinal: 0
			column: Year
			lineageTag: 2111c361-fbd4-40ae-83a7-11dbfe01713b

		level Quarter
			ordinal: 1
			column: Quarter
			lineageTag: 57a52d42-d028-4595-a832-2e02b4337bc2

		level Month
			ordinal: 2
			column: MonthName
			lineageTag: bee3d04e-7de8-4086-b183-5b67a4544e11

		level Day
			ordinal: 3
