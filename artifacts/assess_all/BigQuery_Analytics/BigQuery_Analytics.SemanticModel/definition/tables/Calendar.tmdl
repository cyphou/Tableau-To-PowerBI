table Calendar
	lineageTag: f7cf077a-9ba7-4832-a46b-f4fefae291df

	measure 'Year To Date' = TOTALYTD([Total Revenue], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: d86b246c-3bee-4f1f-8714-c669e050ad75

	measure 'Previous Year' = CALCULATE([Total Revenue], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: d6e273c0-397a-4e85-b623-f4e44e5050cd

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 55b779a1-6004-4704-9635-046e16b8cdd4

	column Date
		dataType: dateTime
		formatString: dd/mm/yyyy
