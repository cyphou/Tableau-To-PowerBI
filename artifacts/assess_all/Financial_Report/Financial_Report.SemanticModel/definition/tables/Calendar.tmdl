	hierarchy 'Date Hierarchy'
		lineageTag: 8ff901eb-c177-4138-b87d-8ae8942a8101

		level Year
			ordinal: 0
			column: Year
			lineageTag: 6608b7b3-8f69-4d3f-af75-733fc6b478ae

		level Quarter
			ordinal: 1
