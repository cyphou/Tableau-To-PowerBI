	hierarchy 'Date Hierarchy'
		lineageTag: f83ca1ed-b626-4fa1-af31-474eb9b742cb

		level Year
			ordinal: 0
			column: Year
			lineageTag: f7d1fd94-433d-4ee4-a96c-35a8365fd08b

		level Quarter
