table Calendar
	lineageTag: 77bd53d2-4b34-4b07-b794-b784e00a6a85

	measure 'Year To Date' = TOTALYTD([Budget Variance], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: aa451a83-0fa4-40a1-a2ef-8886f1c446b7

	measure 'Previous Year' = CALCULATE([Budget Variance], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 16b2b893-019e-4407-b776-293ed5f39e44

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: eb67f542-eb33-4f81-93a3-8558d56b1ae4

	column Date
		dataType: dateTime
