table Calendar
	lineageTag: 6aa35d1d-b9e4-4c42-b288-c80229638a96

	measure 'Year To Date' = TOTALYTD([Budget Variance], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 28e2ac60-8fa1-4784-a5d6-9b90c0a3acbd

	measure 'Previous Year' = CALCULATE([Budget Variance], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 255addba-65a9-4304-88ca-032f8adf7465

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 1c5ef5be-e786-4696-b956-bfdbee5a69f3

	column Date
