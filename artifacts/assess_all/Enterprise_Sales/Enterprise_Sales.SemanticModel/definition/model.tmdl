model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Orders","Customers","Calendar","Target Margin","Top N"]

ref table Orders
ref table Customers
ref table Calendar
ref table 'Target Margin'
ref table 'Top N'

ref relationship b279f23e-4d61-4cb5-91df-f4a692a33f90
ref relationship 26c51d9e-c46e-4707-beca-53fc1d9a5d23
ref relationship 65f51369-6174-4093-8f6b-db5550d7b05d

ref expression DataFolder

ref role 'Territory Access'
ref role 'Is My Account'

ref perspective 'Full Model'

