	hierarchy 'Date Hierarchy'
		lineageTag: 38779c47-614d-4f0d-962d-3805ada56dea

		level Year
			ordinal: 0
			column: Year
			lineageTag: 02c45102-d2eb-46ed-b56a-1c88fa40fc1c

		level Quarter
			ordinal: 1
			column: Quarter
			lineageTag: a4e13702-f9f5-43e5-b192-69bbdecd2928

