table Calendar
	lineageTag: 27f49691-b1b0-4b17-8d25-c07acabb88e3

	measure 'Year To Date' = TOTALYTD([Cost Per Lead], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 88b59e94-6612-40bd-849b-b49fff03c088

	measure 'Previous Year' = CALCULATE([Cost Per Lead], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: dc153c37-9970-4634-8606-570c3dbbc625

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: eb830200-98f3-4997-85c7-e8e9cc88a285

