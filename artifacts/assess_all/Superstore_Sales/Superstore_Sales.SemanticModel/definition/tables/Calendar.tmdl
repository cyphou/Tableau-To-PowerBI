	hierarchy 'Date Hierarchy'
		lineageTag: da23c8db-3ef0-46ae-a37f-f39fe9db5901

		level Year
			ordinal: 0
			column: Year
			lineageTag: 8b1022bf-60ad-4c91-b5d2-96c3f5d18dbb

		level Quarter
			ordinal: 1
