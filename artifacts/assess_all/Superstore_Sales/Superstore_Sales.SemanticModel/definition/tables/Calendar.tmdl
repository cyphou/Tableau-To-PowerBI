table Calendar
	lineageTag: fe4a2269-557f-4853-b881-1738af47c2f7

	measure 'Year To Date' = TOTALYTD([Total Sales], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: b6b67f0c-7eb5-4e47-8bfa-97b45a094b49

	measure 'Previous Year' = CALCULATE([Total Sales], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: d4d8c3f3-6b71-49da-8c22-31177ecc4865

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: eaa3a23d-a921-4a73-9706-3219940e9a76

